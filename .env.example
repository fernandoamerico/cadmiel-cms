# Database — use Neon (neon.tech) free tier or your existing Supabase connection string
DATABASE_URI=postgresql://user:password@host/cadmiel_cms

# Payload secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=your-secret-here

# Vercel Blob — get from Vercel dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Main site URL + token — used to trigger cache revalidation after publishing
MAIN_SITE_URL=https://cadmielconstrutora.com
REVALIDATE_TOKEN=your-shared-secret-here
